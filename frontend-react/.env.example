# Listening mode: choose one
# 'wake-word-api' - Web Speech API continuous listening (requires saying "hey abubakar" to trigger)
# 'websocket-streaming' - Continuous WebSocket streaming to backend (backend detects wake word)
VITE_LISTENING_MODE=wake-word-api

# API endpoints
VITE_API_URL=http://localhost:8080/api
VITE_WEBSOCKET_URL=ws://localhost:8080/ws/voice
